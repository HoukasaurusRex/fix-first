{
  "name": "@fixfirst/infra",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "synth": "yarn build && cdk synth --context env=staging",
    "synth:prod": "yarn build && cdk synth --context env=production",
    "deploy:staging": "yarn build && cdk deploy --context env=staging --all",
    "deploy:prod": "yarn build && cdk deploy --context env=production --all --require-approval broadening",
    "test": "echo \"No infra tests yet\" && exit 0"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.241.0",
    "constructs": "^10.5.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "aws-cdk": "^2.1108.0",
    "typescript": "^5.9.3"
  }
}
